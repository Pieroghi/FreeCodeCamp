<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Survey Form</title>
  </head>
  
  <body>
    <header>
    <h1 id="title">Galactic Expedition Sign-up</h1>
    <p id="description">Join the next frontier. Please tell us about your qualifications for deep-space travel.</p>
    </header>

    <form id="survey-form">
      <div class="form-group">
        <label id="name-label" for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="Enter your name" required>
      </div>

      <div class="form-group">
        <label id="email-label" for="email">Space-Mail (Email)</label>
        <input type="email" id="email" name="email" placeholder="commander@starfleet.com" required>
      </div>

      <div class="form-group">
        <label id="number-label" for="number">Years of Experience (0-50)</label>
        <input type="number" id="number" name="age" min="0" max="50" placeholder="Years">
      </div>

      <div class="form-group">
        <p>What is your preferred role?</p>
        <select id="dropdown" name="role" required>
        <option disabled selected value>Select a role</option>
        <option value="pilot">Starship Pilot</option>
        <option value="scientist">Exobiologist</option>
        <option value="engineer">Warp Drive Engineer</option>
        </select>
      </div>

      <div class="form-group">
        <p>Would you recommend Mars as a vacation spot?</p>
        <label><input name="recommend" value="yes" type="radio" checked> Definitely</label>
        <label><input name="recommend" value="maybe" type="radio"> Maybe</label>
        <label><input name="recommend" value="no" type="radio"> Not breathable enough</label>
      </div>

      <div class="form-group">
        <p>Which galaxies have you visited? (Select all that apply)</p>
        <label><input type="checkbox" name="visited" value="andromeda"> Andromeda</label>
        <label><input type="checkbox" name="visited" value="milkyway"> Milky Way</label>
        <label><input type="checkbox" name="visited" value="sombrero"> Sombrero Galaxy</label>
      </div>

      <div class="form-group">
        <p>Any special skills for the mission?</p>
        <textarea id="comments" name="comments" placeholder="e.g. I speak fluent Martian..."></textarea>
      </div>

      <button type="submit" id="submit">Launch Application</button>
    </form>
  
  <body></body>
</html>
